            <div class="project-links">
              <a href="#" class="btn-project btn-project-primary"><i class="fa-solid fa-play"></i> Live Demo</a>
              <a href="#" class="btn-project btn-project-outline"><i class="fa-brands fa-github"></i> Codebase</a>
            </div>
          </div>
        </div>

