        <h1 class="hero-name">Akansha Raghav</h1>
        <h2 class="hero-title">I am a <span class="typing-text" id="typingElement"></span></h2>
        <p class="hero-tagline">Building scalable, modern, and high-performance web applications</p>
        <div class="hero-buttons">
          <a href="#contact" class="btn btn-glow btn-primary"><i class="fa-solid fa-paper-plane"></i> Hire Me</a>
          <a href="#projects" class="btn btn-glow btn-secondary"><i class="fa-solid fa-eye"></i> View Projects</a>
          <a href="#" class="btn btn-glow btn-outline" download><i class="fa-solid fa-download"></i> Download Resume</a>
        </div>
        <div class="hero-socials">
          <a href="https://github.com/Akansharaghav77" target="_blank" rel="noopener" aria-label="GitHub"><i class="fa-brands fa-github"></i></a>
