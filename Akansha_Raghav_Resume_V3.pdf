            <li>
              <div class="icon-box"><i class="fa-solid fa-phone"></i></div>
              <div class="details-content">
                <span class="detail-label">Call Me</span>
                <a href="tel:6395469224" class="detail-value">+91 63954 69224</a>
              </div>
